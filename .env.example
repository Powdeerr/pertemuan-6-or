# File konfigurasi environment
# Salin file ini menjadi .env dan isi sesuai konfigurasi lokal kamu

# Koneksi database MySQL
# Format: mysql://USERNAME:PASSWORD@HOST:PORT/NAMA_DATABASE
DATABASE_URL="mysql://root:password@localhost:3306/buku_db"

# Secret key untuk JWT (ganti dengan string acak yang panjang)
JWT_SECRET="bootcamp_neo_telemetri_secret_key_2026"

# Port server
PORT=3000
